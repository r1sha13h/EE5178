      }
    ],
    "has_images": false,
    "image_files": []
  },
  {
    "slide": 10,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Harris Detector: Intuition"
      },
      {
        "level": 0,
        "text": "For nearly constant patches, this will be near 0.  For very distinctive patches, this will be larger.  Hence... we want patches where E(u,v) is LARGE."
      }
    ],
    "has_images": false,
    "image_files": []
  },
