    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Taylor Series for 2D Functions"
      },
      {
        "level": 0,
        "text": "First partial derivatives"
      },
      {
        "level": 0,
        "text": "Second partial derivatives"
      },
      {
        "level": 0,
        "text": "Third partial derivatives"
      },
      {
        "level": 0,
        "text": "(Higher order terms)"
      },
