  {
    "slide": 31,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Harris Detector \u2013 Scale Parameters"
      },
      {
        "level": 0,
        "text": "The Harris detector requires two scale  parameters:"
      },
      {
        "level": 1,
        "text": "a differentiation scale \u03c3D for smoothing prior to the  computation of image derivatives,"
      },
      {
        "level": 0,
        "text": "&"
      },
      {
        "level": 1,
        "text": "an integration scale \u03c3I for defining the size of the  Gaussian window (i.e., integrating derivative"
      },
      {
        "level": 0,
        "text": "responses)."
      },
      {
        "level": 0,
        "text": "Typically, \u03c3I=\u03b3\u03c3D"
      }
    ],
    "has_images": false,
    "image_files": []
  },
  {
    "slide": 32,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Invariance to Geometric/Photometric Changes"
      },
      {
        "level": 0,
        "text": "Is the Harris detector invariant to geometric and  photometric changes?"
      },
      {
        "level": 0,
        "text": "Geometric"
      },
      {
        "level": 1,
        "text": "Rotation"
      },
      {
        "level": 1,
        "text": "Scale"
      },
      {
        "level": 1,
        "text": "Affine"
      },
      {
        "level": 0,
        "text": "Photometric"
      },
      {
        "level": 1,
        "text": "Affine intensity change: I(x,y) \uf0ae a I(x,y) + b"
      }
    ],
    "has_images": false,
    "image_files": []
  },
  {
    "slide": 33,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Harris Detector: Rotation Invariance"
      },
      {
        "level": 0,
        "text": "Rotation"
      },
      {
        "level": 0,
        "text": "Ellipse rotates but its shape (i.e. eigenvalues)  remains the same"
      },
      {
        "level": 0,
        "text": "Corner response R is invariant to image rotation"
      }
    ],
    "has_images": false,
    "image_files": []
  },
  {
    "slide": 34,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Harris Detector: Rotation Invariance (cont\u2019d)"
      }
    ],
    "has_images": false,
    "image_files": []
  },
  {
    "slide": 35,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Harris Detector: Scale Invariance"
      },
      {
        "level": 0,
        "text": "All points will  be classified  as edges"
      },
      {
        "level": 0,
        "text": "Scaling"
      },
      {
        "level": 0,
        "text": "Corner"
      },
      {
        "level": 0,
        "text": "Not invariant to scaling (and affine transforms)"
      }
    ],
    "has_images": false,
    "image_files": []
  }
