        "level": 0,
        "text": "Types of Noises in Images"
      },
      {
        "level": 0,
        "text": "Sources of Noise"
      },
      {
        "level": 1,
        "text": "Capture Noise: Noise in the environment of the scene captured"
      },
      {
        "level": 2,
        "text": "Lighting (high lit and low lit)"
      },
      {
        "level": 2,
        "text": "Sensor (temperature fluctuations, electrical interference)"
      },
      {
        "level": 2,
        "text": "Lens (dust, fog etc.)"
      },
      {
        "level": 1,
        "text": "Sampling Noise: Continuous Real World Scene to Discrete Pixels. Can cause aliasing effects"
      },
      {
        "level": 1,
        "text": "Processing Noise: Noise introduced when processing images due to mathematical approximations"
      },
      {
        "level": 1,
        "text": "Image Compression Noise: JPEG Lossy Compression removes finer details"
      }
    ],
