  {
    "slide": 51,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Designing an edge detector\u000bCourtesy Juan Carlos Niebles and Ranjay Krishna"
      },
      {
        "level": 0,
        "text": "Good detection: the optimal detector must minimize the probability of false positives (detecting spurious edges caused by noise), as well as that of true negatives (missing real edges)."
      }
    ],
    "has_images": true,
    "image_files": [
      "/home/rishabh/Documents/IITM/CV/Notes/MD/Images/extracted/Edge detection/slide_51_img_2.png"
    ]
  },
  {
    "slide": 52,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Designing an edge detector\u000bCourtesy Juan Carlos Niebles and Ranjay Krishna"
      },
      {
        "level": 0,
        "text": "Good detection: the optimal detector must minimize the probability of false positives (detecting spurious edges caused by noise), as well as that of false negatives (missing real edges)."
      },
      {
        "level": 0,
        "text": "Good localization: the edges detected must be as close as possible to the true edges."
      }
    ],
    "has_images": true,
    "image_files": [
      "/home/rishabh/Documents/IITM/CV/Notes/MD/Images/extracted/Edge detection/slide_52_img_2.png"
    ]
  },
  {
    "slide": 53,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Designing an edge detector\u000bCourtesy Juan Carlos Niebles and Ranjay Krishna"
      },
      {
        "level": 0,
        "text": "Good detection: the optimal detector must minimize the probability of false positives (detecting spurious edges caused by noise), as well as that of false negatives (missing real edges)."
      },
      {
        "level": 0,
        "text": "Good localization: the edges detected must be as close as possible to the true edges."
      },
      {
        "level": 0,
        "text": "Single response: the detector must return one point only for each true edge point; that is, minimize the number of local maxima around the true edge."
      }
    ],
    "has_images": true,
    "image_files": [
      "/home/rishabh/Documents/IITM/CV/Notes/MD/Images/extracted/Edge detection/slide_53_img_2.png"
