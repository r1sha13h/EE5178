      },
      {
        "level": 0,
        "text": "Edge occurs where gradient reaches a maxima"
      },
      {
        "level": 0,
        "text": "Suppress non-maxima gradient even if it passes threshold"
      },
      {
        "level": 0,
        "text": "Only eight angle directions possible"
      },
      {
        "level": 0,
        "text": "\u2013 Suppress all pixels in each direction which are not maxima \u2013 Do this in each marked pixel neighborhood"
