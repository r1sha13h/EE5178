    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Derivatives Amplifies NOISE\u000bCourtesy Saad J Bedros"
      }
    ],
    "has_images": true,
    "image_files": [
      "/home/rishabh/Documents/IITM/CV/Notes/MD/Images/extracted/Edge detection/slide_31_img_1.png"
