  {
    "slide": 30,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Some practical issues: Effect of NOISE\u000bCourtesy Juan Carlos Niebles and Ranjay Krishna"
      },
      {
        "level": 0,
        "text": "Finite difference filters respond strongly to"
      },
      {
        "level": 0,
        "text": "noise"
      },
      {
        "level": 0,
        "text": "\u2013 Generally, the larger the noise the stronger the response"
      }
    ],
    "has_images": true,
    "image_files": [
      "/home/rishabh/Documents/IITM/CV/Notes/MD/Images/extracted/Edge detection/slide_30_img_2.png"
