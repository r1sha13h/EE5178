  {
    "slide": 54,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "What we will learn today"
      },
      {
        "level": 0,
        "text": "Edge detection"
      },
      {
        "level": 0,
        "text": "Image gradients"
      },
      {
        "level": 0,
        "text": "A simple edge detection"
      },
      {
        "level": 0,
        "text": "Sobel edge detector"
      },
      {
        "level": 0,
        "text": "Canny edge detector"
      }
    ],
    "has_images": false,
    "image_files": []
  },
  {
    "slide": 55,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Canny Edge Detector\u000bCourtesy Juan Carlos Niebles and Ranjay Krishna"
      },
      {
        "level": 0,
        "text": "This is probably the most widely used edge detector in computer vision."
      },
      {
        "level": 0,
        "text": "Theoretically model step-edges corrupted by additive Gaussian noise."
      },
      {
        "level": 0,
        "text": "Canny has shown that the first derivative of the Gaussian closely approximates the operator that optimizes the product of signal-to-noise ratio and localization."
      },
      {
        "level": 0,
        "text": "Canny, John. \"A computational approach to edge detection.\" IEEE Transactions on pattern analysis and machine intelligence 6 (1986): 679-698."
      }
    ],
    "has_images": false,
    "image_files": []
  },
  {
    "slide": 56,
    "title": "",
    "texts": [
      {
        "level": 0,
        "text": "Canny Edge Detector\u000bCourtesy Courtesy Juan Carlos Niebles and Ranjay Krishna"
      },
      {
        "level": 0,
        "text": "Suppress Noise"
      },
      {
        "level": 0,
        "text": "Compute gradient magnitude and direction"
      },
      {
        "level": 0,
        "text": "Apply Non-Maximum Suppression"
      },
      {
        "level": 0,
        "text": "\u2013 Assures minimal response"
      },
      {
        "level": 0,
        "text": "Use hysteresis and connectivity analysis to detect edges"
      }
    ],
    "has_images": false,
    "image_files": []
  },
